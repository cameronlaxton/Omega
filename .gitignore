# Retired scratch audit artifacts — superseded by inbox/sessions/<id>.json
# (audit_events) + reports/run_audits/<id>.audit.md. Root-anchored so the
# committed copies under archive/legacy/ are unaffected; these must never
# reappear at the repo root. Do not regenerate.
/RUN_AUDIT.md
/RUN_TRACE.jsonl

# Phase 7 ETL raw-response cache (knowable-at-the-time snapshot; not source).
# Alias tables (data/aliases) and Sackmann CSV clones (data/external) ARE versioned.
data/cache/

# Local DB / SQLite + FUSE probe artifacts (see OMEGA_COWORK.md §2b "Disk artifacts").
# Harmless leftovers from ad-hoc DB probing and deleted-but-open handles.
*.probe.db
*.probe.db-journal
*.db-wal-test
*.db-wal
*.db-shm
tmp*.probe.db*

# Quarantined malformed session sidecars + diagnostic JSONL event mirror.
inbox/sessions/invalid/
inbox/sessions/*.events.jsonl

# Runtime reports and processed traces (not source truth)
reports/*.txt
reports/run_audits/*.audit.md
inbox/traces/processed/

# Runtime state root (DB, inbox dumps, generated reports) must stay out of git.
var/
/inbox/
/reports/
/omega_traces.db
/omega_traces.db-shm
/omega_traces.db-wal
