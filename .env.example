DATABASE_URL=postgresql+psycopg://omega:omega@localhost:5432/omega
POSTGRES_USER=omega
POSTGRES_PASSWORD=omega
POSTGRES_DB=omega
# HTTP/SSE transport is loopback-only by default. Binding a non-loopback host
# (incl. 0.0.0.0) is refused unless OMEGA_MCP_ALLOW_REMOTE=1 AND OMEGA_MCP_TOKEN
# are both set; remote binds then require Authorization: Bearer <OMEGA_MCP_TOKEN>.
OMEGA_MCP_HOST=127.0.0.1
OMEGA_MCP_PORT=8000
# OMEGA_MCP_ALLOW_REMOTE=1
# OMEGA_MCP_TOKEN=change-me-to-a-long-random-secret
OMEGA_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173
