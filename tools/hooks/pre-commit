#!/bin/sh
#
# Omega pre-commit hook.
#
# Blocks accidental commits of runtime trace files and databases.
# Tracked source of truth lives at tools/hooks/pre-commit; install
# it into .git/hooks/ with:
#
#     omega-install-hooks
#

STAGED=$(git diff --cached --name-only)

BLOCKED=0
for f in $STAGED; do
    case "$f" in
        var/inbox/traces/*.json|var/inbox/traces/processed/*.json|var/inbox/traces/failed/*.json|var/omega_traces.db*|omega_traces.db*)
            echo "[pre-commit] BLOCKED: runtime artifact must not be committed: $f"
            BLOCKED=1
            ;;
    esac
done

if [ "$BLOCKED" = "1" ]; then
    echo "[pre-commit] Unstage with: git reset HEAD var/inbox/traces/ var/omega_traces.db*"
    echo "[pre-commit] To recover stuck traces: omega-ingest-traces --include-processed"
    exit 1
fi

exit 0
