#!/bin/sh
#
# Omega pre-push validation hook.
#
# Runs the validation harness before every push and aborts the push if any
# check fails. Tracked source of truth lives at tools/hooks/pre-push; install
# it into .git/hooks/ with:
#
#     omega-install-hooks
#
# This runs the FULL harness (including the ~2 min test suite). To gate on the
# fast policy/shape checks only, change the line below to add --skip-tests.
# To bypass the hook for a single push:  git push --no-verify
#
set -e

# Resolve the repo root from the hook location (.git/hooks/pre-push).
ROOT="$(git rev-parse --show-toplevel)"

PY=python
command -v python >/dev/null 2>&1 || PY=python3

echo "[pre-push] running Omega validation harness..."
omega-validate-all
